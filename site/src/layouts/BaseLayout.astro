---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto",
          "Oxygen", "Ubuntu", "Cantarell", "Fira Sans", "Droid Sans",
          "Helvetica Neue", sans-serif;
        background-color: #0f1117;
        color: #e2e8f0;
        line-height: 1.6;
      }

      a {
        color: #f0b90b;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
      }

      header {
        background-color: #1a1f2e;
        padding: 30px 0;
        border-bottom: 1px solid #2d333b;
      }

      header h1 {
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 5px;
      }

      header p {
        font-size: 14px;
        color: #8b949e;
      }

      main {
        padding: 40px 0;
      }

      footer {
        background-color: #1a1f2e;
        padding: 20px 0;
        text-align: center;
        color: #8b949e;
        border-top: 1px solid #2d333b;
        margin-top: 40px;
        font-size: 12px;
      }

      @media (max-width: 768px) {
        header h1 {
          font-size: 22px;
        }

        .container {
          padding: 0 15px;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <h1>Daily Food News</h1>
        <p>烘焙食品行业情报 · 每日自动更新</p>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        <p>每日自动更新 · 数据来源：8个人工筛选优质信源</p>
      </div>
    </footer>
  </body>
</html>
