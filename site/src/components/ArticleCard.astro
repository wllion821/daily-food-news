---
interface Props {
  title: string;
  url: string;
  summary: string;
  source_name: string;
  signals: string[];
  score?: number;
}

const { title, url, summary, source_name, signals, score } = Astro.props;

function getScoreColor(value: number) {
  if (value >= 70) return "#5a8f4a";
  if (value >= 40) return "#d4a843";
  return "#b0a090";
}
---

<article class="article-card">
  <div class="article-head">
    {typeof score === "number" && (
      <span class="score-badge" style={`background: ${getScoreColor(score)}`}>
        {score}
      </span>
    )}
    <h3 class="card-title">
      <a href={url} target="_blank">{title}</a>
    </h3>
  </div>

  <div class="article-meta">
    <span>{source_name}</span>
  </div>

  <div class="summary-block">
    <div class="card-summary">{summary}</div>
    <button type="button" class="summary-toggle" aria-expanded="false">展开</button>
  </div>

  {signals.length > 0 && (
    <div class="signals">
      {signals.map((signal) => (
        <span class={signal === "负向风险" ? "signal-tag risk" : "signal-tag"}>
          {signal}
        </span>
      ))}
    </div>
  )}
</article>

<style>
  .article-card {
    background: #ffffff;
    border: 1px solid #e8ddd3;
    border-radius: 12px;
    padding: 16px 20px;
    box-shadow: 0 1px 4px rgba(139, 94, 60, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .article-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 18px rgba(139, 94, 60, 0.12);
  }

  .article-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .score-badge {
    display: inline-flex;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    font-weight: 700;
    font-size: 14px;
  }

  .card-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: #3d2b1f;
    flex: 1;
  }

  .card-title a {
    color: inherit;
  }

  .card-title a:hover {
    color: #c67c4e;
  }

  .article-meta {
    font-size: 12px;
    color: #9c8577;
    margin-bottom: 12px;
  }

  .card-summary {
    font-size: 14px;
    line-height: 1.6;
    color: #5c4033;
    min-height: 72px;
    margin-bottom: 14px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: pre-wrap;
    max-height: 3.2em;
  }

  .article-card.expanded .card-summary {
    -webkit-line-clamp: unset;
    max-height: none;
  }

  .summary-block {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 14px;
  }

  .summary-toggle {
    border: none;
    background: none;
    color: #c67c4e;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    padding: 0;
    align-self: flex-start;
  }

  .summary-toggle {
    min-width: 52px;
  }

  .signals {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .signal-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: 999px;
    background: #f5e6d3;
    color: #8b5e3c;
    font-size: 12px;
    font-weight: 600;
  }

  .signal-tag.risk {
    background: #fdeaea;
    color: #c0392b;
  }

  @media (max-width: 768px) {
    .article-card {
      padding: 16px;
    }

    .card-title {
      font-size: 15px;
    }

    .card-summary {
      font-size: 13px;
    }
  }
</style>
