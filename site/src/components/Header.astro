---
interface Props {
  date: string;
}
const { date } = Astro.props;
---
<header class="page-header">
  <div class="headline-bar"></div>
  <div class="header-inner">
    <div class="header-left">
      <div class="brand-title">Daily Food News</div>
      <div class="brand-subtitle">烘焙食品行业情报</div>
      <div class="brand-date">{date}</div>
      <a href="/daily-food-news/archive/" class="archive-link">📁 归档</a>
    </div>
    <div class="header-right">
      <label class="search-label" for="news-search">快速检索</label>
      <input
        id="news-search"
        type="search"
        placeholder="搜索标题、摘要、来源..."
        class="search-input"
      />
    </div>
  </div>
</header>

<style>
  .page-header {
    background: linear-gradient(180deg, #faf6f1 0%, #f5ede4 100%);
    border: 1px solid #e8ddd3;
    border-radius: 24px;
    padding: 16px 24px 20px;
    margin-bottom: 24px;
  }

  .headline-bar {
    width: 100%;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, #c67c4e 0%, #d4a843 100%);
    margin-bottom: 18px;
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .header-left {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .brand-title {
    font-size: 28px;
    font-weight: 700;
    color: #3d2b1f;
    line-height: 1.1;
  }

  .brand-subtitle,
  .brand-date {
    font-size: 14px;
    color: #9c8577;
  }

  .archive-link {
    font-size: 14px;
    color: #8b5e3c;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .archive-link:hover {
    color: #c67c4e;
  }

  .search-label {
    display: none;
  }

  .search-input {
    width: 320px;
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid #e8ddd3;
    background: #ffffff;
    color: #5c4033;
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s ease;
  }

  .search-input:focus {
    border-color: #c67c4e;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 20px 16px 18px;
    }

    .header-inner {
      flex-direction: column;
      align-items: stretch;
    }

    .search-input {
      width: 100%;
      margin-top: 8px;
    }
  }
</style>
